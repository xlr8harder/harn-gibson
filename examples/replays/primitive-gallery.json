    "sceneRevision": 1,
    "checks": [
      {"path": "primitives.gallery-mesh.kind", "equals": "mesh"},
      {"path": "primitives.gallery-vector.kind", "equals": "svg_layer"},
      {"path": "primitives.gallery-city.kind", "equals": "city_block"},
      {"path": "primitives.gallery-graph.kind", "equals": "node_graph"},
      {"path": "primitives.gallery-ribbon.kind", "equals": "ribbon"},
      {"path": "primitives.gallery-glyphs.kind", "equals": "glyph_layer"},
      {"path": "primitives.gallery-packets.kind", "equals": "particle_field"},
      {"path": "primitives.assistant-stream.kind", "equals": "text_stream"},
      {"path": "animations.gallery-pulse.kind", "equals": "packet_burst"}
